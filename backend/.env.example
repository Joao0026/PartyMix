# MongoDB Atlas Configuration
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create/Sign in to your account
# 3. Create a new cluster
# 4. Click "Connect" and choose "Connect your application"
# 5. Copy the connection string and replace <password> with your database password
# 6. Replace <username> with your database username
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/partymix?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/partymix?retryWrites=true&w=majority

PORT=3001
NODE_ENV=development

# Admin panel (/admin)
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-secret

# AI generation (optional; required for live Groq responses)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Comma-separated frontend origins allowed by CORS.
# Development can be left empty for localhost/LAN access.
CORS_ORIGINS=http://localhost:5173

# For local development (alternative):
# MONGODB_URI=mongodb://localhost:27017/partymix
# Make sure MongoDB is running locally: mongod
